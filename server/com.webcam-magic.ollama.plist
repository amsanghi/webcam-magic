<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- LaunchAgent: runs the Ollama server on login, with CORS allowed for the
     GitHub Pages site. Installed to ~/Library/LaunchAgents by setup.sh. -->
<plist version="1.0">
<dict>
  <key>Label</key><string>com.webcam-magic.ollama</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/ollama</string>
    <string>serve</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>OLLAMA_HOST</key><string>127.0.0.1:11434</string>
    <key>OLLAMA_ORIGINS</key><string>https://amsanghi.github.io,http://localhost:*,http://127.0.0.1:*</string>
    <key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
  </dict>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>/tmp/webcam-magic-ollama.log</string>
  <key>StandardErrorPath</key><string>/tmp/webcam-magic-ollama.log</string>
</dict>
</plist>
